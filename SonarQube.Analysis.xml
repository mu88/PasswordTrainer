<?xml version="1.0" encoding="utf-8"?>
<SonarQubeAnalysisProperties
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="http://www.sonarsource.com/msbuild/integration/2015/1">
  <!-- Exclude static frontend assets from coverage — these are JavaScript files
       served by the web app that cannot be covered by .NET test tooling. -->
  <Property Name="sonar.coverage.exclusions">**/wwwroot/**</Property>
</SonarQubeAnalysisProperties>
